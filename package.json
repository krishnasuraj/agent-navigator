{
  "name": "agent-navigator",
  "productName": "Agent Navigator",
  "description": "Desktop app for managing multiple Claude Code agents in parallel",
  "author": "Krishna Suraj",
  "private": true,
  "version": "0.4.0",
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "dev:test": "electron-vite dev -- --test-sessions=3",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "rebuild": "CXXFLAGS=\"-I$(xcrun --show-sdk-path)/usr/include/c++/v1 -isysroot $(xcrun --show-sdk-path)\" electron-rebuild -f -w node-pty",
    "dist": "electron-vite build && CXXFLAGS=\"-I$(xcrun --show-sdk-path)/usr/include/c++/v1 -isysroot $(xcrun --show-sdk-path)\" electron-builder --mac",
    "dist:all": "electron-vite build && CXXFLAGS=\"-I$(xcrun --show-sdk-path)/usr/include/c++/v1 -isysroot $(xcrun --show-sdk-path)\" electron-builder --mac --win --linux"
  },
  "build": {
    "appId": "com.krishnasuraj.agent-navigator",
    "productName": "Agent Navigator",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "node_modules/**/*",
      "!node_modules/**/build/Release/.deps",
      "!node_modules/**/build/Release/obj.target"
    ],
    "afterSign": "electron/notarize.js",
    "mac": {
      "icon": "build/icon.icns",
      "category": "public.app-category.developer-tools",
      "artifactName": "${name}-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "identity": "5YP76V77Q5",
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "notarize": false
    },
    "dmg": {
      "title": "Agent Navigator",
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "publish": {
      "provider": "github",
      "owner": "krishnasuraj",
      "repo": "agent-navigator"
    },
    "nodeGypRebuild": false,
    "npmRebuild": true
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@electron/notarize": "^3.1.1",
    "@electron/rebuild": "^4.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@vitejs/plugin-react": "^5.1.4",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "chokidar": "^4.0.3",
    "electron": "^33.4.11",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.2.1",
    "vite": "^7.3.1"
  }
}
